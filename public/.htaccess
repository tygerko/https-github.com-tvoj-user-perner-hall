# Perner.Experience – SPA routing pre Apache FTP server
# Nutné pre správne fungovanie React aplikácie v podpriečinku

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /pernerexperience/

  # Neprepisuj existujúce súbory a priečinky
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # Všetky ostatné požiadavky → index.html
  RewriteRule . /pernerexperience/index.html [L]
</IfModule>

# Komprimácia (odporúčané pre výkon)
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

# Cache pre statické assety
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType application/pdf "access plus 1 month"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
</IfModule>
